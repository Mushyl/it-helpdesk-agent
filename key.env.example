# Copy this file to key.env and paste your Anthropic API key.
# key.env is git-ignored and is the single source of truth for secrets.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides (defaults shown) — see src/config.py
# HELPDESK_LLM_MODEL=claude-sonnet-4-6
# HELPDESK_LLM_TIMEOUT=30
# HELPDESK_LLM_MAX_RETRIES=2
# HELPDESK_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# HELPDESK_TOP_K=3
# HELPDESK_LOW_CONFIDENCE_THRESHOLD=0.30
# HELPDESK_JIRA_PROJECT_KEY=IT

# Optional: Slack bot (src/slack_bot.py) — Socket Mode tokens
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
